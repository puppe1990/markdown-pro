{
    "name": "markdown-pro",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "prepare": "husky",
        "precommit": "lint-staged && npm run test",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.14.0",
        "@vitejs/plugin-react": "^5.0.0",
        "@vitest/ui": "^4.1.5",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "typescript": "~5.8.2",
        "typescript-eslint": "^8.59.0",
        "vite": "^6.2.0",
        "vitest": "^4.1.5"
    }
}
